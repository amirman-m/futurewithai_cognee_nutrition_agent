# .env.example — copy this file to .env and fill in your real values.
# NEVER commit .env to version control (it is listed in .gitignore).
#
# Get your DeepSeek API key at: https://platform.deepseek.com/api_keys

# ── DeepSeek / LLM Settings ──────────────────────────────────────────────────

# Your DeepSeek API key. Used by both the LangChain LLM client and Cognee.
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# Cognee reads these vars to configure its internal LLM calls.
LLM_API_KEY=sk-your-deepseek-key-here
LLM_PROVIDER=openai
LLM_MODEL=openai/deepseek-chat
LLM_ENDPOINT=https://api.deepseek.com/v1

# Optional: Skip LLM connection test on startup (set to true if you have network issues)
COGNEE_SKIP_CONNECTION_TEST=true

# Tell LiteLLM to silently drop unsupported parameters (e.g. dimensions param for HuggingFace models)
LITELLM_DROP_PARAMS=true

# ── Embedding Settings ───────────────────────────────────────────────────────

# Use local embeddings (free, no API key needed)
# Options: huggingface, openai
EMBEDDING_PROVIDER=huggingface

# Local embedding model (small and fast) - must include provider prefix
EMBEDDING_MODEL=huggingface/sentence-transformers/all-MiniLM-L6-v2

# Optional: If using OpenAI embeddings instead, uncomment and add your key:
# EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=sk-your-openai-key-here
# EMBEDDING_MODEL=text-embedding-3-small
